# Sanas MCP server configuration.
# Copy to `.env` and fill in the values from your Sanas onboarding email.
# The live tools require the first three; offline tools work without any of them.

SANAS_REMOTE_ENDPOINT=your.remote.endpoint.com
SANAS_ACCOUNT_ID=your_account_id
SANAS_ACCOUNT_SECRET=your_account_secret

# Use TLS for the media path (true/false). Default: true.
SANAS_SECURE_MEDIA=true

# Defaults applied when a tool call omits them.
SANAS_DEFAULT_MODEL=ST_NC3.0
SANAS_DEFAULT_SAMPLE_RATE=16000
